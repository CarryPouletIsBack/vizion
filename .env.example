# Supabase (optionnel : par défaut les valeurs du projet sont utilisées)
# En production : définir VITE_SUPABASE_URL et VITE_SUPABASE_ANON_KEY dans Vercel
# VITE_SUPABASE_URL=https://xxx.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Mapbox GL JS — Vue 3D topographique (page Segment). Obtenir un token : https://account.mapbox.com
# VITE_MAPBOX_ACCESS_TOKEN=pk.xxx

# Données locales : si true, l'app charge les courses depuis public/data/localEventsAndCourses.json
# (généré par npm run export-courses) au lieu de Supabase. Utile pour visualiser hors ligne.
# VITE_USE_LOCAL_COURSES=true

# Configuration Strava OAuth
# Ces variables doivent être configurées dans Vercel (Settings > Environment Variables)
# Obtenir ces valeurs depuis https://www.strava.com/settings/api

# Client ID de votre application Strava
# En production: Configuré dans Vercel comme STRAVA_CLIENT_ID
# En développement local: Peut être défini ici ou dans .env.local
STRAVA_CLIENT_ID=your_strava_client_id_here

# Client Secret (⚠️ Ne jamais exposer côté client)
# En production: Configuré dans Vercel comme STRAVA_CLIENT_SECRET (sécurisé côté serveur)
# En développement local: Peut être défini ici ou dans .env.local
STRAVA_CLIENT_SECRET=your_strava_client_secret_here

# Redirect URI (doit correspondre exactement à celle configurée dans Strava)
# En développement: http://localhost:5173/auth/strava/callback
# En production: https://vizion-blush.vercel.app/auth/strava/callback
# Cette valeur est calculée automatiquement, pas besoin de la définir ici

# Météo Xweather (optionnel — sans config, l'app fonctionne sans température réelle)
# Créer un compte : https://signup.xweather.com/developer
# En production : configurer dans Vercel (XWEATHER_CLIENT_ID, XWEATHER_CLIENT_SECRET)
# Si Vercel "Deployment Protection" est activé, /api/weather peut renvoyer 401 ; l'app continue sans météo.
# XWEATHER_CLIENT_ID=
# XWEATHER_CLIENT_SECRET=

# IA (Mistral) pour conseils de préparation et affinage simulateur
# Créer une clé : https://console.mistral.ai/
# MISTRAL_API_KEY=

# Kaldera — Retours utilisateur : notification Discord à chaque envoi de feedback
# Créer un webhook : serveur Discord > canal #feedbacks-kaldera > Modifier le salon > Intégrations > Webhooks > Nouveau Webhook
# En production : configurer dans Vercel (DISCORD_WEBHOOK_URL)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
